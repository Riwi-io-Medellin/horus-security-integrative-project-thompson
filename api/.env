SKIP_AUTHORIZATION=true
UNIFIED_API_BASE=http://127.0.0.1:8001
KALI_CONTAINER=kali-redteam
SCANNER_DOCKER_NETWORK=lab_net
ALLOW_PUBLIC_TARGETS=true
AUTHORIZED_TARGETS=0.0.0.0/0
SCAN_PROFILE=balanced
NMAP_DEEP_PROBE_TOP_PORTS=1000
NMAP_DEEP_TIMEOUT_SEC=180
HYDRA_ENABLED=true
HYDRA_MAX_SERVICES_PER_SCAN=2
HYDRA_MAX_ATTEMPTS=112
HYDRA_MAX_DURATION_SEC=20
HYDRA_COOLDOWN_SEC=120
HYDRA_TASKS=4
HYDRA_STOP_ON_LOCKOUT=true
HYDRA_STOP_ON_RATE_LIMIT=true
