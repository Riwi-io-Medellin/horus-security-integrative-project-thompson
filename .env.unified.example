SKIP_AUTHORIZATION=true
ALLOW_PUBLIC_TARGETS=true
AUTHORIZED_TARGETS=0.0.0.0/0
SCAN_PROFILE=fast
KALI_CONTAINER=kali-redteam
SCANNER_DOCKER_NETWORK=

AUTO_REMEDIATION=false
ML_MODEL_PATH=./engine/ml/models
ML_INFERENCE_TIMEOUT_MS=100
HONEYPOT_PATHS=~/Documents,~/Desktop,~/Downloads
APFS_SNAPSHOT_INTERVAL_MINUTES=60
ALERT_WEBHOOK_URL=
RISK_SCORE_ALERT_THRESHOLD=75
CORRELATION_RULES_PATH=./engine/correlation_rules.json
AGENT_WS_ENDPOINT=ws://localhost:8001/api/v2/ws/stream
SCANNER_MOCK_MODE=false
